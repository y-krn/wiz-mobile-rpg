{
  "name": "wiz-mobile-rpg",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "preview": "vite preview",
    "test": "npm run test:unit:full && npm run test:browser",
    "test:unit": "node scratch/run_tests.js",
    "test:unit:fast": "FAST=1 node scratch/run_tests.js",
    "test:unit:full": "FULL_TEST=1 node scratch/run_tests.js",
    "test:browser": "playwright test",
    "lint:css": "stylelint \"src/style.css\" \"src/styles/**/*.css\"",
    "lint": "npm run lint:css && eslint . --cache"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@sentry/vite-plugin": "^5.3.0",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "stylelint": "^17.14.0",
    "vite": "^8.0.12"
  },
  "dependencies": {
    "@sentry/browser": "^10.63.0"
  }
}
